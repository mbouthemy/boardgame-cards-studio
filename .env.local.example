# Copy this file to .env.local and add your own PostgreSQL credentials.
# Never commit .env.local.
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/boardgame_card_studio

# S3-compatible image storage. Leave the credentials blank when your runtime
# uses an IAM role instead.
S3_REGION=ap-southeast-1
S3_BUCKET=card-garden-images
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# OpenAI image generation. Keep this value in .env.local only.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
